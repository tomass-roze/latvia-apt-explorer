{
  "name": "latvia-apt-explorer",
  "version": "0.1.0",
  "private": true,
  "description": "Map-first aggregator of Latvian new-construction apartment projects",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "format": "biome format --write",
    "check": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "tsx scripts/run-scraper.ts",
    "build-payload": "tsx scripts/build-payload.ts"
  },
  "dependencies": {
    "@radix-ui/react-slider": "1.3.6",
    "cheerio": "1.2.0",
    "lucide-react": "1.16.0",
    "maplibre-gl": "5.24.0",
    "next": "16.2.6",
    "nuqs": "2.8.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "8.1.1",
    "robots-parser": "3.0.1",
    "usehooks-ts": "3.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "22.10.5",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/ui": "4.1.7",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  }
}
